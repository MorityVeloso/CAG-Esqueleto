{
  "name": "cag-esqueleto",
  "version": "1.0.0",
  "description": "Reusable 5-Layer Context Engineering Module - CAG (Cache-Augmented Generation) replacing traditional RAG",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "sql",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cag",
    "cache-augmented-generation",
    "context-engineering",
    "rag-alternative",
    "claude",
    "anthropic",
    "prompt-caching",
    "ai",
    "llm"
  ],
  "author": "MorityVeloso",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MorityVeloso/CAG-Esqueleto.git"
  },
  "bugs": {
    "url": "https://github.com/MorityVeloso/CAG-Esqueleto/issues"
  },
  "homepage": "https://github.com/MorityVeloso/CAG-Esqueleto#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "zod": "^3.24.4"
  },
  "peerDependencies": {
    "@supabase/supabase-js": "^2.49.4",
    "ioredis": "^5.6.1",
    "tiktoken": "^1.0.21"
  },
  "peerDependenciesMeta": {
    "@supabase/supabase-js": { "optional": true },
    "ioredis": { "optional": true },
    "tiktoken": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^8.57.1",
    "prettier": "^3.5.3",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
